# Real Google AI Studio key. Never commit. Set in Vercel dashboard for prod.
GEMINI_API_KEY=your-google-ai-studio-key

# HS256 signing secret for JWT verification. Must match the secret used by your client app servers to sign JWTs.
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Comma-separated list of Gemini models the clients are allowed to request.
ALLOWED_MODELS=gemini-2.0-flash-exp,gemini-2.5-flash,gemini-2.5-pro,gemini-2.5-flash-preview-native-audio-dialog
