# Real Google AI Studio key. Never commit. Set in Vercel dashboard for prod.
GEMINI_API_KEY=your-google-ai-studio-key

# HS256 signing secret for proxy JWTs. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# JSON array of client projects allowed to mint tokens.
# Each entry: { id, secret, allowedOrigins? }
# allowedOrigins is optional; if omitted, CORS is not origin-checked for that client.
CLIENTS_JSON=[{"id":"qci","secret":"client-secret-1","allowedOrigins":["http://localhost:5173","https://qci.vercel.app"]},{"id":"vkyc","secret":"client-secret-2","allowedOrigins":["http://localhost:5174"]}]

# Comma-separated list of Gemini models the clients are allowed to request.
ALLOWED_MODELS=gemini-2.0-flash-exp,gemini-2.5-flash,gemini-2.5-pro,gemini-2.5-flash-preview-native-audio-dialog
